{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-track-edits.sh clear"
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/rust-fmt.sh",
        "matcher": "Write|StrReplace|ApplyPatch"
      },
      {
        "command": ".cursor/hooks/session-track-edits.sh append",
        "matcher": "Write|StrReplace|ApplyPatch"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/stop-check-followup.sh",
        "loop_limit": 2
      }
    ]
  }
}
