{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":gitSignOff"
  ],
  "rebaseWhen": "behind-base-branch",
  "platformAutomerge": true,
  "prConcurrentLimit": 3,
  "constraints": {
    "rust": "1.94.1"
  },
  "enabledManagers": [
    "cargo",
    "dockerfile",
    "custom.regex",
    "github-actions",
    "pip_requirements"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Super-linter slim digest in scripts/super-linter.sh (track slim-latest digest)",
      "managerFilePatterns": ["/^scripts\\/super-linter\\.sh$/"],
      "matchStrings": ["SL_SHA=\"(?<currentDigest>sha256:[a-f0-9]+)\""],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "ghcr.io/super-linter/super-linter",
      "versioningTemplate": "docker",
      "currentValueTemplate": "slim-latest"
    },
    {
      "customType": "regex",
      "description": "CI taiki-e/install-action: cargo-llvm-cov (ci.yml tool: line)",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/ci\\.yml$/"],
      "matchStrings": ["cargo-llvm-cov@(?<currentValue>[^,\\s]+)"],
      "datasourceTemplate": "crate",
      "depNameTemplate": "cargo-llvm-cov",
      "versioningTemplate": "cargo"
    },
    {
      "customType": "regex",
      "description": "CI taiki-e/install-action: cargo-deny (ci.yml tool: line)",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/ci\\.yml$/"],
      "matchStrings": ["cargo-deny@(?<currentValue>[^,\\s]+)"],
      "datasourceTemplate": "crate",
      "depNameTemplate": "cargo-deny",
      "versioningTemplate": "cargo"
    },
    {
      "customType": "regex",
      "description": "CI taiki-e/install-action: cargo-afl (ci.yml tool: line)",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/ci\\.yml$/"],
      "matchStrings": ["cargo-afl@(?<currentValue>[^,\\s]+)"],
      "datasourceTemplate": "crate",
      "depNameTemplate": "cargo-afl",
      "versioningTemplate": "cargo"
    },
    {
      "customType": "regex",
      "description": "CI taiki-e/install-action: cargo-about (ci.yml tool: line)",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/ci\\.yml$/"],
      "matchStrings": ["cargo-about@(?<currentValue>[^,\\s]+)"],
      "datasourceTemplate": "crate",
      "depNameTemplate": "cargo-about",
      "versioningTemplate": "cargo"
    },
    {
      "customType": "regex",
      "description": "rust-toolchain.toml stable channel (rust-lang/rust release tags)",
      "managerFilePatterns": ["/^rust-toolchain\\.toml$/"],
      "matchStrings": [
        "channel\\s*=\\s*\"(?<currentValue>\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "rust-lang/rust",
      "depNameTemplate": "rust-lang/rust",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "description": "GitHub Actions: one PR for all minor/patch updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "github-actions-minor-patch"
    },
    {
      "description": "Super-linter image: digest-only grouped PRs",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/super-linter/super-linter"],
      "matchUpdateTypes": ["digest"],
      "groupName": "super-linter-slim-digest"
    },
    {
      "description": "CI cargo tools (taiki-e/install-action): minor/patch in one PR",
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["crate"],
      "matchFileNames": [".github/workflows/ci.yml"],
      "matchPackageNames": [
        "cargo-llvm-cov",
        "cargo-deny",
        "cargo-afl",
        "cargo-about"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "ci-cargo-install-tools-minor-patch"
    },
    {
      "description": "rust-toolchain.toml: stable channel minor/patch in one PR",
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["github-tags"],
      "matchFileNames": ["rust-toolchain.toml"],
      "matchPackageNames": ["rust-lang/rust"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "rust-toolchain-channel-minor-patch"
    },
    {
      "description": "Packaging Docker: Rust builder base image",
      "matchManagers": ["dockerfile"],
      "matchFileNames": ["packaging/docker/Dockerfile"],
      "matchPackageNames": ["rust"],
      "groupName": "packaging-docker-rust-slim"
    },
    {
      "description": "REUSE tooling: hash-pinned pip lockfile (ensure-reuse.sh)",
      "matchManagers": ["pip_requirements"],
      "matchFileNames": ["scripts/requirements-reuse.txt"],
      "groupName": "reuse-tooling-pip"
    },
    {
      "description": "Rust workspace: regenerate THIRD-PARTY-LICENSES after Cargo updates",
      "matchManagers": ["cargo"],
      "postUpgradeTasks": {
        "commands": ["bash scripts/renovate-post-upgrade-licenses.sh"],
        "executionMode": "branch",
        "fileFilters": ["THIRD-PARTY-LICENSES"],
        "installTools": {
          "rust": {},
          "python": {}
        }
      }
    },
    {
      "description": "Workspace Rust crates: minor/patch in one PR",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "rust-workspace-minor-patch"
    },
    {
      "description": "Enable GitHub platform auto-merge after CI for non-major updates",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin"],
      "automerge": true
    },
    {
      "description": "Major updates require manual review and merge",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Rust workspace deps: no automerge until cargo rollout verified",
      "matchManagers": ["cargo"],
      "automerge": false
    }
  ]
}
