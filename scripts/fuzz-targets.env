# Maps fuzz target names to source paths they exercise.
# When using --changed, only targets whose paths changed are run.
# Add one line per fuzz target when adding a new manifest parser.

config_toml=spd/src/config.rs
requirements_txt=spd-python/src/parser.rs
parse_config_set_arg=spd/src/cli.rs
