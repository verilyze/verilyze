# Maps fuzz target names to source paths they exercise.
# When using --changed, only targets whose paths changed are run.
# Add one line per fuzz target when adding a new manifest parser.

config_toml=vlz/src/config.rs
requirements_txt=vlz-python/src/parser/requirements.rs
parse_config_set_arg=vlz/src/cli.rs
pyproject_toml=vlz-python/src/parser/pyproject.rs
pipfile=vlz-python/src/parser/pipfile.rs
pylock_toml=vlz-python/src/resolver/lock_parser.rs
poetry_lock=vlz-python/src/resolver/lock_parser.rs
