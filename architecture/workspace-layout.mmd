%% Workspace layout: crates/core/ (vlz, vlz-db, vlz-manifest-finder, vlz-manifest-parser,
%% vlz-cve-client, vlz-report, vlz-integrity, vlz-plugin-macro, vlz-reachability,
%% vlz-reachability-trait), crates/languages/
%% (vlz-python, vlz-rust, vlz-go), crates/providers/ (vlz-cve-provider-nvd, vlz-cve-provider-github,
%% vlz-cve-provider-sonatype), crates/db-backends/ (vlz-db-redb), tests/fuzz
graph TD
    %% Core binary
    A["vlz (binary crate)"]
    %% Macro crate (used by binary for plugin registration)
    M["vlz-plugin-macro"]
    %% Library crates
    B["vlz-manifest-finder"]
    C["vlz-manifest-parser"]
    D["vlz-cve-client"]
    D2["vlz-cve-provider-nvd (optional, nvd feature)"]
    D3["vlz-cve-provider-github (optional, github feature)"]
    D4["vlz-cve-provider-sonatype (optional, sonatype feature)"]
    E["vlz-db (trait definitions)"]
    F["vlz-report"]
    G["vlz-integrity"]
    K["vlz-reachability"]
    L["vlz-reachability-trait"]
    P["vlz-python (optional, python feature)"]
    R["vlz-rust (optional, rust feature)"]
    Q["vlz-go (optional, go feature)"]
    %% Concrete implementations (plug‑ins)
    H["vlz-db-redb (default DatabaseBackend)"]
    I["vlz-db-sqlite (optional, future)"]
    J["vlz-db-mem (test/mock, future)"]
    %% Edges from binary to libraries
    A --> B
    A --> C
    A --> D
    A --> D2
    A --> D3
    A --> D4
    A --> E
    A --> F
    A --> G
    A --> K
    A --> L
    A --> P
    A --> R
    A --> Q
    A --> M
    %% Edges from libraries to the traits they expose (collapsed for brevity)
    B -.->|defines| ManifestFinder
    C -.->|defines| Parser
    D -.->|defines| CveProvider
    D2 -.->|implements| CveProvider
    D3 -.->|implements| CveProvider
    D4 -.->|implements| CveProvider
    E -.->|defines| DatabaseBackend
    F -.->|defines| Reporter
    G -.->|defines| IntegrityChecker
    L -.->|defines| ReachabilityAnalyzer
    K -.->|uses| ReachabilityAnalyzer
    K -.->|applies| ReachabilityAnalyzer
    %% Registration edges (plug‑in discovery)
    H -->|"vlz_register! (feature = redb)"| A
    I -->|"vlz_register! (feature = sqlite)"| A
    J -->|"vlz_register! (feature = mem)"| A
    P -.->|implements| ReachabilityAnalyzer
    R -.->|implements| ReachabilityAnalyzer
    Q -.->|implements| ReachabilityAnalyzer
