flowchart TD
    subgraph Providers ["CVE providers"]
        GH["GitHub Advisory"]
        SO["Sonatype OSS Index"]
    end

    subgraph Auth ["Credential resolution (at fetch time)"]
        GH --> GHCheck{VLZ_GITHUB_TOKEN set?}
        GHCheck -- yes --> GHUseSPD["Use VLZ_GITHUB_TOKEN"]
        GHCheck -- no --> GHCheck2{GITHUB_TOKEN set?}
        GHCheck2 -- yes --> GHUseStd["Use GITHUB_TOKEN"]
        GHCheck2 -- no --> GHUnauth["Unauthenticated (lower rate limits)"]
        SO --> SOCheck{VLZ_SONATYPE_EMAIL and VLZ_SONATYPE_TOKEN set?}
        SOCheck -- yes --> SOBasic["HTTP Basic auth"]
        SOCheck -- no --> SOError["Return clear error (missing credentials)"]
    end

    subgraph Never ["Credentials never"]
        N1["Written to cache"]
        N2["Logged"]
        N3["Included in error output (SEC-020)"]
    end
