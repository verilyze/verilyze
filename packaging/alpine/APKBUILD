# Maintainer: Travis Post <post.travis@gmail.com>
pkgname=verilyze
pkgver=0.1.0
pkgrel=0
pkgdesc="Fast, modular Software Composition Analysis tool"
url="https://github.com/tpost/verilyze"
arch="x86_64"
license="GPL-3.0-or-later"
makedepends="cargo rust openssl-dev"
source="$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz"

build() {
  cargo build --release --locked
}

check() {
  cargo test --release --locked
}

package() {
  install -Dm755 target/release/vlz \
    "$pkgdir"/usr/bin/vlz

  install -Dm644 verilyze.conf.example \
    "$pkgdir"/etc/verilyze.conf

  install -Dm644 verilyze.conf.example \
    "$pkgdir"/usr/share/doc/"$pkgname"/verilyze.conf.example

  install -Dm644 man/verilyze.conf.5 \
    "$pkgdir"/usr/share/man/man5/verilyze.conf.5
}

sha512sums=""
