pkgname=verilyze
pkgver=0.2.1
pkgrel=0
pkgdesc="Fast, modular Software Composition Analysis tool"
url="https://github.com/verilyze/verilyze"
arch="x86_64"
license="GPL-3.0-or-later"
makedepends="cargo rust openssl-dev"
source="$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz"

build() {
  cargo build --release --locked
  ./scripts/generate_completions.sh ./target/release/vlz
  # THIRD-PARTY-LICENSES is committed; see make generate-third-party-licenses
}

check() {
  cargo test --release --locked --features vlz/testing
}

package() {
  install -Dm755 target/release/vlz \
    "$pkgdir"/usr/bin/vlz

  install -Dm644 verilyze.conf.example \
    "$pkgdir"/etc/verilyze.conf

  install -Dm644 verilyze.conf.example \
    "$pkgdir"/usr/share/doc/"$pkgname"/verilyze.conf.example

  install -Dm644 man/vlz.1 \
    "$pkgdir"/usr/share/man/man1/vlz.1

  install -Dm644 man/verilyze.conf.5 \
    "$pkgdir"/usr/share/man/man5/verilyze.conf.5

  install -Dm644 completions/vlz.bash \
    "$pkgdir"/usr/share/bash-completion/completions/vlz
  install -Dm644 completions/_vlz \
    "$pkgdir"/usr/share/zsh/site-functions/_vlz
  install -Dm644 completions/vlz.fish \
    "$pkgdir"/usr/share/fish/vendor_completions.d/vlz.fish

  install -Dm644 LICENSES/GPL-3.0-or-later.txt \
    "$pkgdir"/usr/share/licenses/"$pkgname"/LICENSE
  install -Dm644 THIRD-PARTY-LICENSES \
    "$pkgdir"/usr/share/licenses/"$pkgname"/THIRD-PARTY-LICENSES
}

sha512sums=""
