# Canonical OBS coordinates for automation and docs.
# Update these values when moving from a personal namespace to a
# project-maintained namespace.
OBS_CHANGES_FILENAME=verilyze.changes
OBS_LEGACY_CHANGES_FILENAME=verilyze.spec.changes
OBS_MAINTAINER="Travis Post <post.travis@gmail.com>"
OBS_PACKAGE=verilyze
OBS_PROJECT=home:tpost:verilyze
OBS_RPMLINTRC_FILENAME=verilyze-rpmlintrc
OBS_SPEC_FILENAME=verilyze.spec
OBS_WAIT_POLL_INTERVAL_SECONDS=60
OBS_WAIT_TIMEOUT_SECONDS=7200
